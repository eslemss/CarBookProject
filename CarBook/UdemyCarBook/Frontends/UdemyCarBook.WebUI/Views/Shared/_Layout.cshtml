<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function showLoginWarning() {
        let timerInterval;
        Swal.fire({
            title: 'Üyelik Gerekiyor',
            html: 'Araç kiralamak için üye olmanız gerekmektedir. <br><br> <b>5</b> saniye içinde giriş sayfasına yönlendiriliyorsunuz...',
            timer: 5000,
            timerProgressBar: true,
            confirmButtonColor: '#ff9f1c',
            confirmButtonText: 'Hemen Giriş Yap',
            didOpen: () => {
                Swal.showLoading();
                const b = Swal.getHtmlContainer().querySelector('b');
                timerInterval = setInterval(() => {
                    // Kalan süreyi saniye cinsinden ekrana basar
                    b.textContent = Math.ceil(Swal.getTimerLeft() / 1000);
                }, 100);
            },
            willClose: () => {
                clearInterval(timerInterval);
            }
        }).then((result) => {
            /* Kullanıcı ister 'Hemen Giriş Yap' desin,
               isterse 5 saniye beklesin; sonuçta returnUrl ile Login'e gider.
            */
            const currentPath = window.location.pathname + window.location.search;
            window.location.href = "/Login/Index?returnUrl=" + encodeURIComponent(currentPath);
        });
    }
</script>